// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  BARBER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Plan {
  START
  PRO
  ENTERPRISE
}

model Tenant {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  logo          String?
  primaryColor  String?
  secondaryColor String?
  accentColor   String?
  isActive      Boolean  @default(true)

  users         User[]
  services      Service[]
  barbers       Barber[]
  clients       Client[]
  appointments  Appointment[]
  subscription  Subscription?

  createdAt     DateTime @default(now())
}

model Subscription {
  id        Int      @id @default(autoincrement())
  plan      Plan
  status    SubscriptionStatus
  stripeId  String?
  tenantId  Int      @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model User {
  id        Int    @id @default(autoincrement())
  name      String
  email     String @unique
  password  String
  role      Role
  tenantId  Int?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])
}

model Service {
  id        Int    @id @default(autoincrement())
  name      String
  price     Float
  duration  Int
  tenantId  Int
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}

model Barber {
  id        Int    @id @default(autoincrement())
  name      String
  tenantId  Int
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}

model Client {
  id        Int    @id @default(autoincrement())
  name      String
  phone     String
  tenantId  Int
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}

model Appointment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  serviceId Int
  barberId  Int
  clientId  Int
  tenantId  Int

  service   Service  @relation(fields: [serviceId], references: [id])
  barber    Barber   @relation(fields: [barberId], references: [id])
  client    Client   @relation(fields: [clientId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}
